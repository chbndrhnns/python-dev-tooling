// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
  "name": "ruff + uv Playground",
  "image": "mcr.microsoft.com/devcontainers/python:3-3.12-trixie",

  "containerEnv": {
    "UV_LINK_MODE": "copy"
  },

  // Install uv and ruff on container creation
  "onCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && echo 'export PATH=\"$HOME/.cargo/bin:$PATH\"' >> ~/.bashrc",
  "postStartCommand": "source ~/.bashrc && uv sync && (grep -qxF 'source .venv/bin/activate' ~/.bashrc 2>/dev/null || echo 'source .venv/bin/activate' >> ~/.bashrc) && (grep -qxF '[[ -f ~/.bashrc ]] && source ~/.bashrc' ~/.bash_profile 2>/dev/null || echo '[[ -f ~/.bashrc ]] && source ~/.bashrc' >> ~/.bash_profile)",

  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/root/.cargo/bin"
  },

  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "charliermarsh.ruff",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },
        "ruff.enable": true,
        "ruff.lint.enable": true,
        "python.defaultInterpreterPath": ".venv/bin/python"
      }
    }
  }
}
